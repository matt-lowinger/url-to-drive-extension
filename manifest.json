{
  "manifest_version": 3,
  "name": "URL to Google Drive",
  "version": "1.0.0",
  "description": "Save any URL to Google Drive as a clickable redirect link",
  "permissions": [
    "identity",
    "tabs"
  ],
  "oauth2": {
    "client_id": "YOUR_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
